      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "widgets": [
    {
      "name": "FORJA - Streak",
      "short_name": "Streak",
      "description": "Muestra tu racha de entrenos actual",
      "tag": "forja-streak",
      "template": "forja-streak-widget",
      "ms_ac_template": "widgets/streak-template.json",
      "data": "widgets/streak-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "screenshots/screen-1-mobile.png",
          "sizes": "1290x2796",
          "label": "Widget de streak"
        }
      ],
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred"

  "share_target": {
    "action": "/FORJA/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+forja",
      "url": "/FORJA/?deeplink=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/FORJA/import",
      "accept": {
        "application/json": [".json"]
